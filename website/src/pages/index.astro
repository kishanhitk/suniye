---
import Layout from "../layouts/Layout.astro";

const heroWords = "Your voice. Your machine. Your text.".split(" ");
const githubUrl = "https://github.com/kishanhitk/suniye";
const downloadUrl = "https://github.com/kishanhitk/suniye/releases/latest/download/Suniye.dmg";




const steps = [
  {
    num: "01",
    title: "Hold your hotkey",
    desc: "Press and hold Fn/Globe — or any shortcut you configure. A floating indicator appears.",
  },
  {
    num: "02",
    title: "Speak naturally",
    desc: "Talk at your normal pace. Audio is captured locally through your microphone.",
  },
  {
    num: "03",
    title: "Text appears",
    desc: "Release the key. Your speech is transcribed on-device and inserted at your cursor.",
  },
];

const features = [
  {
    title: "Runs on your Mac",
    desc: "A 600 MB speech model runs entirely on-device using sherpa-onnx. No internet needed for transcription. No server. No cloud.",
  },
  {
    title: "Instant transcription",
    desc: "No network round-trip. Your voice becomes text in milliseconds, not seconds. The model runs in memory — always warm, always ready.",
  },
  {
    title: "Works in any app",
    desc: "Text is inserted at your cursor via macOS Accessibility APIs. Mail, Slack, VS Code, Notes, your terminal — everywhere.",
  },
  {
    title: "Optional LLM polish",
    desc: "Connect any OpenAI-compatible endpoint to clean up grammar, fix punctuation, or apply domain-specific vocabulary. Off by default.",
  },
  {
    title: "One configurable shortcut",
    desc: "Default is Fn/Globe. Change it to any modifier combo you like. Hold to talk, release to transcribe. No menus, no buttons.",
  },
  {
    title: "Open source, MIT licensed",
    desc: "Full source on GitHub. Read every line. No telemetry, no tracking, no surprises. Build from source if you want.",
  },
];
---

<Layout>
  <!-- ── Nav ──────────────────────────────── -->
  <nav class="fixed top-0 z-50 w-full border-b border-border/60 bg-bg/90 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/suniye-icon.png" alt="Suniye" class="h-7 w-7 rounded-[5px]" />
        <span class="font-display text-base tracking-tight">Suniye</span>
      </a>
      <div class="flex items-center gap-5">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener"
          class="font-display text-sm text-muted transition-colors hover:text-ink"
        >
          GitHub
        </a>
        <a
          href={downloadUrl}
          class="rounded-lg bg-ink px-4 py-2 font-display text-sm text-bg transition-colors hover:bg-ink/85"
        >
          Download
        </a>
      </div>
    </div>
  </nav>

  <main>
    <!-- ── Hero ─────────────────────────────── -->
    <section class="relative overflow-hidden pt-36 pb-24 md:pt-44 md:pb-32">
      <div class="mx-auto max-w-6xl px-6">
        <div class="max-w-3xl">
          <!-- Waveform SVG — decorative -->
          <svg
            class="mb-8 h-10 w-auto text-accent md:h-14"
            viewBox="0 0 160 80"
            fill="none"
            aria-hidden="true"
          >
            <path
              class="waveform-path"
              d="M 8 50 Q 14 50 20 42 L 40 10 L 62 70 L 84 10 L 106 70 L 124 36 Q 130 26 140 26"
              stroke="currentColor"
              stroke-width="7"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>

          <h1 class="font-display text-4xl leading-tight tracking-tight md:text-6xl md:leading-[1.1]">
            {heroWords.map((word, i) => (
              <span
                class="hero-word"
                style={`animation-delay: ${0.1 + i * 0.1}s`}
              >
                {word}{" "}
              </span>
            ))}
          </h1>

          <p class="fade-in mt-6 max-w-xl text-lg leading-relaxed text-muted md:text-xl">
            Suniye is open-source dictation for macOS. Speech recognition runs
            locally — nothing leaves your machine. Hold one key, speak, release.
          </p>

          <div class="fade-in mt-10 flex flex-wrap items-center gap-4">
            <a
              href={downloadUrl}
              class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 font-display text-sm text-white transition-colors hover:bg-accent-hover"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3" />
              </svg>
              Download for macOS
            </a>
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 font-display text-sm text-ink transition-colors hover:bg-surface"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
              </svg>
              View on GitHub
            </a>
          </div>

          <div class="fade-in mt-5 max-w-lg">
            <p class="flex items-center gap-1 font-display text-[10px] text-muted/50">
              If macOS says "App is damaged", run this command
              <span class="group relative cursor-help">
                <svg class="h-2.5 w-2.5 text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M12 16v-4M12 8h.01" />
                </svg>
                <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 w-56 -translate-x-1/2 rounded-lg border border-border bg-surface px-3 py-2 text-left font-body text-xs leading-relaxed text-muted opacity-0 shadow-lg transition-opacity group-hover:opacity-100">
                  Suniye is not signed with an Apple Developer Certificate ($99/year), so the app is unsigned. macOS quarantines unsigned apps by default. This command removes the quarantine attribute.
                </span>
              </span>
            </p>
            <div class="mt-1.5 inline-flex items-center rounded-md border border-border/40 bg-ink/[0.02]">
              <code class="flex-1 overflow-x-auto px-3 py-1.5 font-display text-[10px] text-ink/50">
                xattr -rd com.apple.quarantine /Applications/Suniye.app
              </code>
              <button
                id="copy-hero-cmd"
                class="copy-btn flex-none border-l border-border/30 px-2 py-1.5 text-muted/30 transition-colors hover:text-ink"
                aria-label="Copy command"
              >
                <svg class="copy-icon h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                </svg>
                <svg class="check-icon h-3 w-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </button>
            </div>
          </div>

          <p class="fade-in mt-4 font-display text-xs tracking-wide text-muted/70">
            <span id="latest-version"></span>macOS 26+ &middot; Alpha &middot; MIT License
          </p>
        </div>
      </div>

      <!-- Background decoration — large faint waveform -->
      <svg
        class="pointer-events-none absolute -right-20 top-24 hidden h-[320px] w-auto text-border/40 lg:block"
        viewBox="0 0 160 80"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M 8 50 Q 14 50 20 42 L 40 10 L 62 70 L 84 10 L 106 70 L 124 36 Q 130 26 140 26"
          stroke="currentColor"
          stroke-width="4"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </section>

    <!-- ── How it works ─────────────────────── -->
    <section class="border-t border-border/60 py-24 md:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="reveal font-display text-sm uppercase tracking-widest text-muted">
          How it works
        </h2>

        <div class="mt-14 grid gap-12 md:grid-cols-3 md:gap-8">
          {steps.map((step, i) => (
            <div class="reveal" style={`transition-delay: ${i * 0.12}s`}>
              <span class="font-display text-5xl tracking-tighter text-accent/25">
                {step.num}
              </span>
              <h3 class="mt-3 font-display text-lg tracking-tight">
                {step.title}
              </h3>
              <p class="mt-2 leading-relaxed text-muted">
                {step.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Features ─────────────────────────── -->
    <section class="border-t border-border/60 bg-surface/50 py-24 md:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="reveal font-display text-sm uppercase tracking-widest text-muted">
          Built for real work
        </h2>

        <div class="mt-14 grid gap-x-12 gap-y-14 md:grid-cols-2 lg:grid-cols-3">
          {features.map((f, i) => (
            <div
              class="reveal border-l-2 border-accent/20 pl-5"
              style={`transition-delay: ${i * 0.08}s`}
            >
              <h3 class="font-display text-base tracking-tight">{f.title}</h3>
              <p class="mt-2 text-[15px] leading-relaxed text-muted">
                {f.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Privacy ──────────────────────────── -->
    <section class="border-t border-border/60 py-24 md:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <div class="reveal max-w-3xl">
          <h2 class="font-display text-3xl leading-snug tracking-tight md:text-5xl md:leading-tight">
            Every word you dictate could be
            <span class="text-accent">training data.</span>
          </h2>
          <p class="mt-2 font-display text-3xl leading-snug tracking-tight text-muted md:text-5xl md:leading-tight">
            Unless it never leaves your machine.
          </p>
        </div>

        <div class="reveal mt-12 grid max-w-4xl gap-8 md:grid-cols-2" style="transition-delay: 0.15s">
          <div>
            <h3 class="font-display text-sm uppercase tracking-widest text-muted">
              The problem
            </h3>
            <p class="mt-4 leading-relaxed text-muted">
              Cloud dictation services process your voice on remote servers.
              Your private notes, medical records, business plans — all passing
              through infrastructure you don't control. That audio can be stored,
              analyzed, and used to train models without your explicit consent.
            </p>
          </div>
          <div>
            <h3 class="font-display text-sm uppercase tracking-widest text-muted">
              Suniye's approach
            </h3>
            <p class="mt-4 leading-relaxed text-muted">
              A 600 MB speech model runs directly on your Mac. Voice is processed
              in memory, transcribed locally, and never touches a network. The only
              network calls Suniye makes are to check for app updates on GitHub.
            </p>
            <p class="mt-4 text-sm leading-relaxed text-muted/70">
              When you enable the optional LLM cleanup, transcribed text (not audio)
              is sent to the provider you choose. This is opt-in and disabled by default.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Tech specs ───────────────────────── -->
    <section class="border-t border-border/60 bg-surface/50 py-24 md:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="reveal font-display text-sm uppercase tracking-widest text-muted">
          Under the hood
        </h2>

        <div class="reveal mt-14 overflow-x-auto" style="transition-delay: 0.1s">
          <table class="w-full max-w-lg font-display text-sm">
            <tbody class="divide-y divide-border/60">
              <tr>
                <td class="py-3 pr-8 tracking-wide text-muted">Platform</td>
                <td class="py-3">macOS 26+</td>
              </tr>
              <tr>
                <td class="py-3 pr-8 tracking-wide text-muted">UI</td>
                <td class="py-3">SwiftUI</td>
              </tr>
              <tr>
                <td class="py-3 pr-8 tracking-wide text-muted">Speech engine</td>
                <td class="py-3">
                  <a href="https://github.com/k2-fsa/sherpa-onnx" target="_blank" rel="noopener" class="underline decoration-border underline-offset-4 transition-colors hover:text-accent">
                    sherpa-onnx
                  </a>
                </td>
              </tr>
              <tr>
                <td class="py-3 pr-8 tracking-wide text-muted">Model</td>
                <td class="py-3">NVIDIA NeMo Parakeet TDT 0.6B (int8)</td>
              </tr>
              <tr>
                <td class="py-3 pr-8 tracking-wide text-muted">Model size</td>
                <td class="py-3">~600 MB (one-time download)</td>
              </tr>
              <tr>
                <td class="py-3 pr-8 tracking-wide text-muted">License</td>
                <td class="py-3">
                  <a href={`${githubUrl}/blob/main/LICENSE`} target="_blank" rel="noopener" class="underline decoration-border underline-offset-4 transition-colors hover:text-accent">
                    MIT
                  </a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ── Download CTA ─────────────────────── -->
    <section class="border-t border-border/60 py-24 md:py-32">
      <div class="mx-auto max-w-6xl px-6 text-center">
        <div class="reveal mx-auto max-w-xl">
          <h2 class="font-display text-3xl tracking-tight md:text-4xl">
            Try Suniye
          </h2>
          <p class="mt-4 leading-relaxed text-muted">
            Download the latest release or build from source. Requires macOS 14
            (Sonoma) or later. The speech model (~600 MB) downloads automatically
            on first launch.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
            <a
              href={downloadUrl}
              class="inline-flex items-center gap-2 rounded-lg bg-accent px-7 py-3.5 font-display text-sm text-white transition-colors hover:bg-accent-hover"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3" />
              </svg>
              Download Latest Release
            </a>
            <a
              href={`${githubUrl}#build-from-source`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-lg border border-border px-7 py-3.5 font-display text-sm text-ink transition-colors hover:bg-surface"
            >
              Build from Source
            </a>
          </div>

          <!-- Quarantine fix note -->
          <div class="mt-8 mx-auto">
            <p class="flex items-center justify-center gap-1.5 font-display text-xs text-muted/70">
              If macOS says "App is damaged", run this command
              <span class="group relative cursor-help">
                <svg class="h-3.5 w-3.5 text-muted/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M12 16v-4M12 8h.01" />
                </svg>
                <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 w-56 -translate-x-1/2 rounded-lg border border-border bg-surface px-3 py-2 text-left font-body text-xs leading-relaxed text-muted opacity-0 shadow-lg transition-opacity group-hover:opacity-100">
                  Suniye is not signed with an Apple Developer Certificate ($99/year), so the app is unsigned. macOS quarantines unsigned apps by default. This command removes the quarantine attribute.
                </span>
              </span>
            </p>
            <div class="mt-2.5 flex items-center rounded-lg border border-border/80 bg-ink/[0.03]">
              <code class="flex-1 overflow-x-auto px-4 py-2.5 font-display text-[13px] text-ink/80">
                xattr -rd com.apple.quarantine /Applications/Suniye.app
              </code>
              <button
                id="copy-quarantine-cmd"
                class="copy-btn flex-none border-l border-border/60 px-3 py-2.5 text-muted/60 transition-colors hover:text-ink"
                aria-label="Copy command"
              >
                <svg class="copy-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                </svg>
                <svg class="check-icon h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </button>
            </div>
          </div>

          <p class="mt-6 inline-block rounded-full border border-accent/20 bg-accent/5 px-4 py-1.5 font-display text-xs tracking-wide text-accent">
            Alpha — expect rough edges
          </p>
        </div>
      </div>
    </section>
  </main>

  <!-- ── Footer ─────────────────────────────── -->
  <footer class="border-t border-border/60 py-10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 md:flex-row">
      <div class="flex items-center gap-2.5">
        <img src="/suniye-icon.png" alt="" class="h-5 w-5 rounded-[3px]" />
        <span class="font-display text-sm text-muted">
          Suniye &middot; MIT License
        </span>
      </div>
      <div class="flex items-center gap-6 font-display text-sm text-muted">
        <a href={githubUrl} target="_blank" rel="noopener" class="transition-colors hover:text-ink">
          GitHub
        </a>
        <a href={`${githubUrl}/blob/main/CONTRIBUTING.md`} target="_blank" rel="noopener" class="transition-colors hover:text-ink">
          Contributing
        </a>
        <a href={`${githubUrl}/issues`} target="_blank" rel="noopener" class="transition-colors hover:text-ink">
          Issues
        </a>
      </div>
    </div>
    <div class="mx-auto mt-4 max-w-6xl px-6">
      <div class="flex flex-col items-center md:items-start">
        <p class="flex items-center gap-1 font-display text-[10px] text-muted/50">
          If macOS says "App is damaged", run this command
          <span class="group relative cursor-help">
            <svg class="h-2.5 w-2.5 text-muted/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 16v-4M12 8h.01" />
            </svg>
            <span class="pointer-events-none absolute bottom-full left-1/2 z-10 mb-2 w-56 -translate-x-1/2 rounded-lg border border-border bg-surface px-3 py-2 text-left font-body text-xs leading-relaxed text-muted opacity-0 shadow-lg transition-opacity group-hover:opacity-100">
              Suniye is not signed with an Apple Developer Certificate ($99/year), so the app is unsigned. macOS quarantines unsigned apps by default. This command removes the quarantine attribute.
            </span>
          </span>
        </p>
        <div class="mt-1.5 inline-flex items-center rounded-md border border-border/40 bg-ink/[0.02]">
          <code class="flex-1 overflow-x-auto px-3 py-1.5 font-display text-[10px] text-ink/50">
            xattr -rd com.apple.quarantine /Applications/Suniye.app
          </code>
          <button
            class="copy-btn flex-none border-l border-border/30 px-2 py-1.5 text-muted/30 transition-colors hover:text-ink"
            aria-label="Copy command"
          >
            <svg class="copy-icon h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
            </svg>
            <svg class="check-icon h-3 w-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </footer>

  <!-- ── Scroll reveal observer ─────────────── -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

    // Copy quarantine command to clipboard
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        await navigator.clipboard.writeText(
          "xattr -rd com.apple.quarantine /Applications/Suniye.app"
        );
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 2000);
      });
    });

    // Fetch latest version from GitHub
    fetch("https://api.github.com/repos/kishanhitk/suniye/releases/latest")
      .then((r) => r.ok ? r.json() : null)
      .then((data) => {
        if (data?.tag_name) {
          const el = document.getElementById("latest-version");
          if (el) el.textContent = data.tag_name + " · ";
        }
      })
      .catch(() => {});
  </script>
</Layout>
