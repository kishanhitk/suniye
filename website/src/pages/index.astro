---
import Layout from "../layouts/Layout.astro";

const features = [
  {
    title: "Runs locally on your Mac",
    description: "No audio leaves your machine. No API calls. No cloud dependency.",
    icon: "🔒"
  },
  {
    title: "Fast & accurate",
    description: "On-device processing means instant transcription with high accuracy. No network latency."
  },
  {
    title: "Highly customizable",
    description: "Configure shortcuts, enable optional LLM layer for text cleanup and formatting."
  },
  {
    title: "Open source",
    description: "Full transparency. Audit the code. No hidden data collection."
  }
];

const useCases = [
  {
    label: "Notes & drafts",
    text: "Get ideas out before you overthink them."
  },
  {
    label: "Code comments",
    text: "Document your work without breaking flow."
  },
  {
    label: "Email & chat",
    text: "Reply fast when typing feels slow."
  },
  {
    label: "Meeting transcripts",
    text: "Capture action items in real time."
  },
  {
    label: "Form filling",
    text: "Move through repetitive fields faster."
  },
  {
    label: "Company confidential work",
    text: "Keep trade secrets off someone else's servers."
  }
];

const workflow = [
  {
    step: "01",
    title: "Press your shortcut",
    description: "Hold the key you configured. Suniye starts listening."
  },
  {
    step: "02",
    title: "Speak naturally",
    description: "Talk like you think. No special phrasing needed."
  },
  {
    step: "03",
    title: "Release and continue",
    description: "Text appears where your cursor is. Keep working."
  }
];

const faq = [
  {
    q: "What about accuracy?",
    a: "Local models are highly accurate for general speech. Accuracy varies by model size and your accent/background noise. You can swap models to match your needs."
  },
  {
    q: "How is this better than Whisper Flow or cloud solutions?",
    a: "Your audio and transcriptions never leave your machine. No third-party servers. No subscription. No company secrets ending up in someone else's cloud. You control everything."
  },
  {
    q: "What about privacy?",
    a: "Zero cloud uploads. Speech recognition runs entirely on your Mac. Text goes directly to the active app—no intermediate storage."
  },
  {
    q: "Can I customize it?",
    a: "Fully. Configure shortcuts, swap transcription models, enable optional LLM processing for text cleanup or formatting, adjust sensitivity."
  },
  {
    q: "Is it open source?",
    a: "Yes. Code, documentation, and model choices are transparent. Audit everything. Contribute."
  },
  {
    q: "What macOS versions?",
    a: "macOS 13+. Requires microphone access and accessibility permissions."
  }
];

const container = "mx-auto w-[min(1200px,calc(100%-48px))]";
const sectionLabel = "text-xs font-semibold uppercase tracking-widest text-gray-500";
const sectionTitle = "text-4xl md:text-5xl font-bold tracking-tight text-gray-900";
const body = "text-lg text-gray-600 leading-relaxed";
const ctaPrimary = "inline-flex items-center justify-center h-12 px-8 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition-colors";
const ctaSecondary = "inline-flex items-center justify-center h-12 px-8 rounded-lg border border-gray-300 text-gray-900 font-semibold hover:bg-gray-50 transition-colors";
---

<Layout title="Suniye — Local ASR for macOS" description="Fast, private, open-source speech-to-text for macOS. Keep your data on your machine.">
  <main class="bg-white text-gray-900">
    {/* Hero */}
    <section class="relative overflow-hidden bg-gradient-to-b from-gray-50 via-white to-white pt-20 pb-32 md:pt-32 md:pb-40">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 right-[-200px] w-[600px] h-[600px] bg-blue-100/30 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-[-100px] w-[500px] h-[500px] bg-gray-100/40 rounded-full blur-3xl"></div>
      </div>

      <div class={`${container} relative`}>
        {/* Header */}
        <div class="flex items-center justify-between mb-16 md:mb-20">
          <div class="flex items-center gap-3">
            <img src="/suniye-icon.png" alt="Suniye" class="w-10 h-10 rounded-lg" />
            <span class="text-xl font-bold">Suniye</span>
          </div>
          <nav class="hidden md:flex items-center gap-12 text-sm text-gray-600">
            <a href="#why" class="hover:text-gray-900 transition-colors">Why it works</a>
            <a href="#how" class="hover:text-gray-900 transition-colors">How it flows</a>
            <a href="#faq" class="hover:text-gray-900 transition-colors">FAQ</a>
          </nav>
          <a href="https://github.com/kishanhitk/suniye/releases/latest" target="_blank" rel="noreferrer" class={ctaSecondary}>
            Download
          </a>
        </div>

        {/* Hero Content */}
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div>
            <p class={`${sectionLabel} mb-4`}>For macOS</p>
            <h1 class={`${sectionTitle} mb-6`}>
              Local dictation. Your data, your Mac.
            </h1>
            <p class={`${body} mb-8 max-w-md`}>
              Hold a key. Speak. Your words land where your cursor is. Fast, accurate, and everything stays on your machine.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="https://github.com/kishanhitk/suniye/releases/latest" target="_blank" rel="noreferrer" class={ctaPrimary}>
                Download for macOS
              </a>
              <a href="#how" class={ctaSecondary}>
                See how it works
              </a>
            </div>
            <p class="text-sm text-gray-500 mt-8">
              macOS 13+. Open source. No cloud. No tracking.
            </p>
          </div>

          <div class="relative hidden md:block">
            <div class="bg-gray-100 rounded-2xl border border-gray-200 overflow-hidden shadow-lg">
              <div class="bg-gray-900 text-white px-4 py-3 flex items-center gap-2 text-xs">
                <span class="w-3 h-3 rounded-full bg-red-400"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
                <span class="w-3 h-3 rounded-full bg-green-400"></span>
              </div>
              <div class="bg-white p-8 min-h-96 flex flex-col justify-center">
                <div class="space-y-3 text-gray-700 font-mono text-sm">
                  <p class="text-gray-400"># Hold Fn and speak...</p>
                  <p class="text-gray-600">Send the project update to Maya</p>
                  <p class="text-gray-600">before the afternoon review</p>
                  <p class="mt-6 text-gray-400"># Text lands right here</p>
                </div>
                <div class="mt-8 pt-6 border-t border-gray-200">
                  <div class="flex gap-1 justify-center">
                    <div class="w-1 h-8 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 0s"></div>
                    <div class="w-1 h-10 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 0.1s"></div>
                    <div class="w-1 h-6 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 0.2s"></div>
                    <div class="w-1 h-12 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 0.3s"></div>
                    <div class="w-1 h-7 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 0.4s"></div>
                  </div>
                  <p class="text-center text-xs text-gray-500 mt-4">Listening...</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Why it works */}
    <section id="why" class="py-24 md:py-32 border-t border-gray-200">
      <div class={container}>
        <div class="mb-16">
          <p class={sectionLabel}>Core features</p>
          <h2 class={`${sectionTitle} mt-4`}>Built for your Mac. Not the cloud.</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          {features.map((feature) => (
            <div class="flex gap-6">
              <div class="flex-shrink-0 text-4xl">{feature.icon}</div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{feature.title}</h3>
                <p class={body}>{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* How it flows */}
    <section id="how" class="py-24 md:py-32 bg-gray-50 border-t border-gray-200">
      <div class={container}>
        <div class="mb-16">
          <p class={sectionLabel}>Workflow</p>
          <h2 class={`${sectionTitle} mt-4 max-w-2xl`}>Three steps. No extra UI. No friction.</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {workflow.map((item) => (
            <div class="border-l-2 border-blue-600 pl-8 py-4">
              <div class="text-5xl font-bold text-gray-200 mb-4">{item.step}</div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>
              <p class={body}>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Use cases */}
    <section class="py-24 md:py-32 border-t border-gray-200">
      <div class={container}>
        <div class="mb-16">
          <p class={sectionLabel}>Where it helps</p>
          <h2 class={`${sectionTitle} mt-4`}>For the work you actually do.</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {useCases.map((item) => (
            <div class="border-b border-gray-200 pb-8">
              <p class="text-sm font-semibold uppercase tracking-widest text-gray-500 mb-2">{item.label}</p>
              <p class={body}>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Privacy */}
    <section class="py-24 md:py-32 bg-gray-900 text-white border-t border-gray-800">
      <div class={container}>
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">Privacy first</p>
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">
              Your secrets stay yours.
            </h2>
            <p class="text-lg text-gray-300 leading-relaxed">
              No cloud. No third parties. No servers. Speech recognition runs entirely on your Mac. Your audio never leaves your machine, and neither do your transcriptions.
            </p>
            <p class="text-lg text-gray-400 mt-6">
              Perfect for sensitive work: confidential emails, proprietary code, meeting notes, anything you wouldn't want on someone else's servers.
            </p>
          </div>

          <div class="bg-gray-800 rounded-2xl border border-gray-700 p-8">
            <div class="space-y-6">
              <div>
                <p class="text-sm font-semibold text-gray-400 mb-2">AUDIO</p>
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                  <p class="text-gray-300">Processed locally. Never uploaded.</p>
                </div>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-400 mb-2">TRANSCRIPTION</p>
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                  <p class="text-gray-300">Stored locally. No cloud sync.</p>
                </div>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-400 mb-2">MODELS</p>
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                  <p class="text-gray-300">Open source. Auditable. Transparent.</p>
                </div>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-400 mb-2">DATA</p>
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                  <p class="text-gray-300">No tracking. No analytics. No ads.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section id="faq" class="py-24 md:py-32 border-t border-gray-200">
      <div class={container}>
        <div class="mb-16">
          <p class={sectionLabel}>Questions</p>
          <h2 class={`${sectionTitle} mt-4`}>FAQ</h2>
        </div>

        <div class="max-w-3xl space-y-8">
          {faq.map((item) => (
            <div class="border-b border-gray-200 pb-8">
              <h3 class="text-xl font-bold text-gray-900 mb-3">{item.q}</h3>
              <p class={body}>{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 md:py-32 bg-blue-600 text-white border-t border-blue-700">
      <div class={container}>
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-widest text-blue-200 mb-4">Ready to start</p>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">
            Your Mac. Your data. Your control.
          </h2>
          <p class="text-xl text-blue-100 mb-8">
            Download Suniye and get started in minutes.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="https://github.com/kishanhitk/suniye/releases/latest" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center h-12 px-8 rounded-lg bg-white text-blue-600 font-semibold hover:bg-gray-100 transition-colors">
              Download for macOS
            </a>
            <a href="https://github.com/kishanhitk/suniye" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center h-12 px-8 rounded-lg border border-white text-white font-semibold hover:bg-white/10 transition-colors">
              View on GitHub
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
