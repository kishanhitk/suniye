---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Suniye — Private Dictation for macOS",
  description = "Open-source, local-first dictation. Hold one key, speak, and your words appear as text — right where your cursor is. No audio leaves your Mac.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf8f5" />
    <link rel="icon" type="image/png" href="/suniye-icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/suniye-icon.png" />
  </head>
  <body class="min-w-[320px] bg-bg font-body text-ink antialiased">
    <slot />
  </body>
</html>
